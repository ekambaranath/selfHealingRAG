# Ollama Configuration (local LLM — no API key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi3:mini          # recommended for 16GB RAM

# Alternative models (uncomment to switch):
# OLLAMA_MODEL=mistral:7b       # faster, less accurate
# OLLAMA_MODEL=llama3.1:8b      # better quality, needs 32GB RAM
# OLLAMA_MODEL=llama3.1:70b     # best quality, needs 64GB RAM
# OLLAMA_MODEL=gemma2:9b        # Google model, great instruction following

# RAG Configuration
MAX_RETRIES=3
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_DOCS=4
MAX_TOKENS=1024
TEMPERATURE=0.1

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_db

# Logging
LOG_LEVEL=INFO
